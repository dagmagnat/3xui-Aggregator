<%- include('partials_header', { pageTitle: 'Клиенты', pageSubtitle: 'Импорт и синхронизация клиентов с основного 3x-ui сервера', activePage: 'clients' }) %>

<% if (message) { %>
  <div class="alert ok"><%= message %></div>
<% } %>

<% if (error) { %>
  <div class="alert err"><%= error %></div>
<% } %>

<div class="grid">
  <section class="card span-12">
    <h2>Режим работы</h2>
    <p class="muted">Ручное создание клиентов в агрегаторе отключено. Сначала создай клиента на основном 3x-ui сервере, затем импортируй его сюда. Агрегатор подтянет клиента и синхронизирует его с остальными узлами.</p>
  </section>

  <section class="card span-6">
    <h2>Импорт клиентов из существующей панели</h2>
    <form method="post" action="/clients/import">
      <div class="field">
        <label>Узел-источник</label>
        <select name="node_id" required>
          <option value="">Выбери узел</option>
          <% nodes.forEach(node => { %>
            <option value="<%= node.id %>"><%= (node.country_flag || '') %> <%= node.country_name_ru || node.name %> (inbound <%= node.inbound_id %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="actions">
        <button type="submit">Импортировать клиентов</button>
      </div>
    </form>
  </section>

  <section class="card span-6">
    <h2>Синхронизация подписок</h2>
    <form method="post" action="/clients/refresh-subscriptions">
      <div class="field">
        <label>Узел-источник для обновления</label>
        <select name="node_id" required>
          <option value="">Выбери узел</option>
          <% nodes.forEach(node => { %>
            <option value="<%= node.id %>"><%= (node.country_flag || '') %> <%= node.country_name_ru || node.name %> (inbound <%= node.inbound_id %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="actions">
        <button type="submit" class="secondary">Обновить подписки</button>
      </div>
    </form>
    <p class="muted">Синхронизация сверяет текущих клиентов с выбранным основным сервером, обновляет исходные подписки и добавляет недостающие связи.</p>
  </section>

  <section class="card span-12">
    <h2>Список клиентов</h2>

    <% if (!clients.length) { %>
      <p class="muted">Пока нет импортированных клиентов.</p>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Логин</th>
              <th>UUID</th>
              <th>Подписка</th>
              <th>Создан</th>
              <th>Действия</th>
            </tr>
          </thead>
          <tbody>
            <% clients.forEach(client => { %>
              <tr>
                <td><%= client.id %></td>
                <td><strong><%= client.login %></strong></td>
                <td class="mono"><%= client.uuid %></td>
                <td class="mono"><a href="<%= baseUrl %>/sub/<%= client.sub_slug %>" target="_blank"><%= baseUrl %>/sub/<%= client.sub_slug %></a></td>
                <td><%= client.created_at %></td>
                <td>
                  <div class="actions">
                    <a href="/clients/<%= client.id %>" class="link-btn secondary">Открыть</a>
                    <form method="post" action="/clients/<%= client.id %>/delete" class="inline-form" onsubmit="return confirm('Удалить клиента со всех узлов?')">
                      <button type="submit" class="danger">Удалить</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</div>

<%- include('partials_footer') %>
