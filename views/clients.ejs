<%- include('partials_header', { pageTitle: 'Клиенты', pageSubtitle: 'Создание, импорт и управление подписками', activePage: 'clients' }) %>
<%
  function flagIcon(code) {
    const cc = String(code || '').toLowerCase();
    if (!cc) return '';
    return '<img class="flag-icon" src="https://flagcdn.com/w20/' + cc + '.png" alt="" loading="lazy">';
  }
  function nodeName(node) {
    const suffix = (node.label_suffix || '').trim();
    const baseName = node.country_name_ru || node.name;
    return suffix ? (/^\d+$/.test(suffix) ? `${baseName}-${suffix}` : `${baseName} / ${suffix}`) : baseName;
  }
  function dateForInput(ts) {
    if (!ts || Number(ts) <= 0) return '';
    const d = new Date(Number(ts));
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }
%>

<% if (message) { %><div class="alert ok"><%= message %></div><% } %>
<% if (error) { %><div class="alert err"><%= error %></div><% } %>

<div id="toast" class="toast">Скопировано</div>

<div class="row">
  <div class="card">
    <h2>Создать клиента</h2>
    <form method="post" action="/clients">
      <div class="form-grid clean-form">
        <div class="field">
          <label>Логин</label>
          <input name="login" placeholder="<%= nextLogin || 'user001' %>" />
          <small class="hint">Если оставить пустым, будет создан автоматически: <%= nextLogin || 'user001' %>.</small>
        </div>

        <div class="field">
          <label>Комментарий</label>
          <input name="comment" placeholder="Например: имя клиента, телефон, заметка" />
          <small class="hint">По этому полю тоже работает поиск. Передаётся в комментарий клиента 3x-ui.</small>
        </div>

        <div class="field half">
          <label>Срок в днях</label>
          <input name="duration_days" type="number" min="0" value="30" />
          <small class="hint">0 = без даты окончания. Если задан лимит трафика, reset передаётся в 3x-ui на этот срок.</small>
        </div>

        <div class="field half">
          <label>Общий лимит трафика, ГБ</label>
          <input name="traffic_gb" type="number" min="0" step="1" value="0" />
          <small class="hint">0 = без лимита. Применяется ко всем узлам, если возле узла не указан отдельный лимит.</small>
        </div>

        <div class="field half">
          <label>Лимит IP</label>
          <input name="limit_ip" type="number" min="1" value="1" required />
        </div>
      </div>

      <div class="nodes-head">
        <div>
          <label>На каких узлах создать</label>
          <small class="hint">Отдельный лимит ГБ возле узла имеет приоритет над общим лимитом.</small>
        </div>
        <label class="select-all-box">
          <input type="checkbox" id="selectAllNodes" />
          <span>Выбрать все</span>
        </label>
      </div>

      <div class="checkbox-list node-list">
        <% nodes.forEach(node => { %>
          <label class="node-item">
            <input class="node-check" type="checkbox" name="node_ids" value="<%= node.id %>" />
            <span class="node-info">
              <strong><%- flagIcon(node.country_code) %> <%= nodeName(node) %></strong>
              <small>inbound <%= node.inbound_id %></small>
            </span>
            <input class="node-gb-input" name="node_traffic_gb_<%= node.id %>" type="number" min="0" step="1" placeholder="ГБ" />
          </label>
        <% }) %>
      </div>

      <button type="submit">Создать клиента на узлах</button>
    </form>
  </div>

  <div class="card">
    <h2>Импорт и синхронизация</h2>

    <form method="post" action="/clients/import">
      <label>Основной узел-источник</label>
      <select name="node_id" required>
        <% nodes.forEach(node => { %>
          <option value="<%= node.id %>"><%= nodeName(node) %> (inbound <%= node.inbound_id %>)</option>
        <% }) %>
      </select>
      <button type="submit">Импортировать клиентов</button>
    </form>

    <form method="post" action="/clients/refresh-subscriptions" style="margin-top:14px;">
      <label>Узел-источник для обновления</label>
      <select name="node_id" required>
        <% nodes.forEach(node => { %>
          <option value="<%= node.id %>"><%= nodeName(node) %> (inbound <%= node.inbound_id %>)</option>
        <% }) %>
      </select>
      <button type="submit">Синхронизировать подписки</button>
    </form>

    <p style="margin-top:12px;">Импорт берёт клиентов из выбранного узла, сохраняет UUID/subId и создаёт таких же клиентов на остальных узлах.</p>
  </div>
</div>

<div class="card">
  <h2>Массовое удаление</h2>
  <form method="post" action="/clients/delete-all" onsubmit="return confirm('Удалить всех клиентов выбранным способом?')">
    <label>Режим удаления</label>
    <select name="delete_mode">
      <option value="aggregator">Только из агрегатора</option>
      <option value="secondary">Из агрегатора и вторичных узлов</option>
      <option value="all">Из агрегатора и всех узлов</option>
    </select>
    <button class="danger" type="submit">Удалить всех клиентов</button>
  </form>
</div>

<div class="card clients-card">
  <h2>Все клиенты</h2>

  <form method="get" action="/clients" class="search-form">
    <input name="q" value="<%= q || '' %>" placeholder="Поиск по имени, логину, UUID или комментарию" />
    <button type="submit" class="secondary">Найти</button>
    <% if (q) { %><a class="link-btn secondary" href="/clients">Сбросить</a><% } %>
  </form>

  <form method="post" action="/clients/bulk-delete" onsubmit="return confirm('Удалить выбранных клиентов?')">
    <div class="bulk-row">
      <div>
        <label>Режим удаления выбранных</label>
        <select name="delete_mode">
          <option value="aggregator">Только из агрегатора</option>
          <option value="secondary">Из агрегатора и вторичных узлов</option>
          <option value="all">Из агрегатора и всех узлов</option>
        </select>
      </div>
      <button class="danger" type="submit">Удалить выбранных</button>
    </div>

    <div class="table-wrap">
      <table class="clients-table">
        <thead>
          <tr>
            <th class="check-col"><input class="inline" type="checkbox" onclick="toggleAllClients(this)" /></th>
            <th>ID</th>
            <th>Имя</th>
            <th>Логин</th>
            <th>Комментарий</th>
            <th>Лимит</th>
            <th>Статус</th>
            <% if (showSubLinks) { %><th class="link-col">Подписка</th><% } %>
            <th class="link-col">JSON</th>
            <th class="actions-col">Действия</th>
          </tr>
        </thead>
        <tbody>
        <% clients.forEach(client => {
          const subUrl = `${baseUrl}/sub/${client.sub_slug}`;
          const jsonUrl = `${baseUrl}/json/${client.sub_slug}`;
          const clientEnabled = client.enabled !== 0;
        %>
          <tr>
            <td class="check-col"><input class="inline client-check" type="checkbox" name="client_ids" value="<%= client.id %>" /></td>
            <td><%= client.id %></td>
            <td><%= client.display_name %></td>
            <td><%= client.login %></td>
            <td class="comment-cell"><%= client.comment || "-" %></td>
            <td class="limit-cell">
              <div class="limit-summary">
                <span class="limit-main"><% if (client.traffic_gb && client.traffic_gb > 0) { %><%= client.traffic_gb %> ГБ<% } else { %>∞<% } %></span>
                <span class="limit-sep">/</span>
                <span class="limit-main"><% if (client.duration_days && client.duration_days > 0) { %><%= client.duration_days %> дн.<% } else { %>∞<% } %></span>
              </div>
              <% if (client.node_limits && client.node_limits.some(nl => nl.client_node_id && ((nl.traffic_gb && nl.traffic_gb > 0) || nl.enabled === 0))) { %>
                <div class="node-limits" aria-label="Лимиты по узлам">
                  <% client.node_limits.filter(nl => nl.client_node_id && ((nl.traffic_gb && nl.traffic_gb > 0) || nl.enabled === 0)).forEach(nl => { 
                    const suffix = (nl.label_suffix || '').trim();
                    const nodeTitle = suffix ? ((nl.country_name_ru || nl.name) + ' / ' + suffix) : (nl.country_name_ru || nl.name);
                  %>
                    <div class="node-limit-row <%= nl.enabled === 0 ? 'disabled' : '' %>">
                      <span class="node-limit-name"><%= nodeTitle %></span>
                      <span class="node-limit-value"><%= nl.enabled === 0 ? 'выкл.' : nl.traffic_gb + ' ГБ' %></span>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </td>
            <td><span class="badge <%= clientEnabled ? 'online' : 'offline' %>"><%= clientEnabled ? 'Включён' : 'Отключён' %></span></td>
            <% if (showSubLinks) { %>
            <td class="link-col">
              <div class="btn-row">
                <button type="button" class="btn-main" onclick="copySubLink('<%= subUrl %>', this)">Скопировать SUB</button>
                <button type="button" class="btn-qr" onclick="showQr('<%= subUrl %>', '<%= client.login %> · SUB')">QR</button>
              </div>
            </td>
            <% } %>
            <td class="link-col">
              <div class="btn-row">
                <button type="button" class="btn-main" onclick="copySubLink('<%= jsonUrl %>', this)">Скопировать JSON</button>
                <button type="button" class="btn-qr" onclick="showQr('<%= jsonUrl %>', '<%= client.login %> · JSON')">QR</button>
              </div>
            </td>
            <td class="actions-col">
              <div class="actions-stack">
                <a class="btn-main" href="/open/<%= client.sub_slug %>" target="_blank">Открыть</a>
                <button type="button" class="btn-secondary" onclick="openClientEditor(<%= client.id %>)">Редактор</button>
              </div>
            </td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
  </form>
</div>

<% clients.forEach(client => { 
  const clientEnabled = client.enabled !== 0;
%>
  <div id="clientEditor-<%= client.id %>" class="modal hidden" onclick="closeClientEditor(event, <%= client.id %>)">
    <div class="modal-card editor-modal" onclick="event.stopPropagation()">
      <button type="button" class="modal-close" onclick="hideClientEditor(<%= client.id %>)">×</button>
      <h2>Редактор клиента</h2>
      <p class="muted"><code><%= client.uuid %></code></p>

      <form method="post" action="/clients/<%= client.id %>/edit">
        <input type="hidden" name="back" value="/clients" />
        <div class="form-grid clean-form">
          <div class="field half">
            <label>Имя клиента</label>
            <input name="display_name" value="<%= client.display_name %>" required />
          </div>
          <div class="field half">
            <label>Логин / Email</label>
            <input name="login" value="<%= client.login %>" required />
          </div>
          <div class="field half">
            <label>Комментарий</label>
            <input name="comment" value="<%= client.comment || '' %>" placeholder="Заметка для поиска" />
          </div>
          <div class="field half">
            <label>Лимит IP</label>
            <input name="limit_ip" type="number" min="1" value="<%= client.limit_ip || 1 %>" />
          </div>
          <div class="field half">
            <label>Новый срок в днях</label>
            <input name="duration_days" type="number" min="0" value="<%= client.duration_days || 0 %>" />
            <small class="hint">0 = без срока. При сохранении срок считается заново от текущего момента.</small>
          </div>
          <div class="field half">
            <label>Общий лимит трафика, ГБ</label>
            <input name="traffic_gb" type="number" min="0" step="1" value="<%= client.traffic_gb || 0 %>" />
          </div>
        </div>

        <h3>Узлы клиента</h3>
        <p class="muted">Снимите галочку, чтобы отключить клиенту конкретный узел. Поле ГБ задаёт лимит только для этого региона; пусто = общий лимит.</p>
        <div class="checkbox-list node-list">
          <% client.node_limits.forEach(row => {
            const nodeLabel = [row.country_flag, row.country_name_ru || row.country_code || row.name, row.label_suffix].filter(Boolean).join(' ');
          %>
            <label class="node-item node-edit-row">
              <input class="inline" type="checkbox" name="node_enabled_<%= row.node_id %>" value="1" <%= row.client_node_id && row.enabled !== 0 ? 'checked' : '' %> />
              <span class="node-info"><strong><%= nodeLabel %></strong><small><%= row.client_node_id ? (row.enabled !== 0 ? 'узел включён' : 'узел отключён для клиента') : 'узел не назначен' %></small></span>
              <input class="node-gb-input" name="node_traffic_gb_<%= row.node_id %>" type="number" min="0" step="1" value="<%= row.traffic_gb || '' %>" placeholder="ГБ" />
            </label>
          <% }) %>
        </div>
        <div class="modal-actions">
          <button type="submit" class="btn-main">Сохранить</button>
        </div>
      </form>

      <hr class="soft-sep" />

      <form method="post" action="/clients/<%= client.id %>/extend" class="extend-form">
        <input type="hidden" name="back" value="/clients" />
        <label>Продлить срок</label>
        <div class="btn-row stretch-row">
          <input name="days" type="number" min="1" value="30" />
          <button type="submit" class="btn-main">Продлить на дней</button>
        </div>
      </form>

      <form method="post" action="/clients/<%= client.id %>/toggle" class="modal-actions">
        <input type="hidden" name="back" value="/clients" />
        <button type="submit" class="<%= clientEnabled ? 'btn-danger' : 'btn-secondary' %>"><%= clientEnabled ? 'Отключить клиента' : 'Включить клиента' %></button>
      </form>
    </div>
  </div>
<% }) %>

<div id="qrModal" class="modal hidden" onclick="hideQr(event)">
  <div class="modal-card" onclick="event.stopPropagation()">
    <button class="modal-close" onclick="closeQr()">×</button>
    <h2 id="qrTitle">QR</h2>
    <img id="qrImg" alt="QR" />
    <p class="muted" id="qrText"></p>
  </div>
</div>

<script>
function showToast(text) {
  const el = document.getElementById('toast');
  if (!el) return;
  el.textContent = text || 'Скопировано';
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 1300);
}
function copySubLink(text, btn) {
  navigator.clipboard.writeText(text).then(() => {
    if (btn) {
      const old = btn.textContent;
      btn.textContent = 'Скопировано';
      setTimeout(() => btn.textContent = old, 1200);
    }
    showToast('Ссылка скопирована');
  }).catch(() => showToast('Не удалось скопировать'));
}
function toggleAllClients(source) { document.querySelectorAll('.client-check').forEach(cb => cb.checked = source.checked); }
function showQr(text, title) {
  document.getElementById('qrTitle').textContent = title || 'QR';
  document.getElementById('qrText').textContent = text;
  document.getElementById('qrImg').src = '/qr?text=' + encodeURIComponent(text);
  document.getElementById('qrModal').classList.remove('hidden');
}
function closeQr() { document.getElementById('qrModal').classList.add('hidden'); }
function hideQr(e) { if (e.target.id === 'qrModal') closeQr(); }
function openClientEditor(id) { document.getElementById('clientEditor-' + id).classList.remove('hidden'); }
function hideClientEditor(id) { document.getElementById('clientEditor-' + id).classList.add('hidden'); }
function closeClientEditor(e, id) { if (e.target.id === 'clientEditor-' + id) hideClientEditor(id); }
document.addEventListener('DOMContentLoaded', () => {
  const selectAll = document.getElementById('selectAllNodes');
  if (selectAll) {
    selectAll.addEventListener('change', () => {
      document.querySelectorAll('.node-check').forEach(cb => cb.checked = selectAll.checked);
    });
  }
});
</script>

<%- include('partials_footer') %>
