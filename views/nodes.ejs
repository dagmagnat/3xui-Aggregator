<%- include('partials_header', { pageTitle: 'Узлы', pageSubtitle: 'Добавление, проверка и управление 3x-ui узлами', activePage: 'nodes' }) %>

<% if (message) { %>
  <div class="alert ok"><%= message %></div>
<% } %>

<% if (error) { %>
  <div class="alert err"><%= error %></div>
<% } %>

<div class="grid">
  <section class="card span-6">
    <h2>Добавить узел</h2>
    <form method="post" action="/nodes">
      <div class="form-grid">
        <div class="field">
          <label>Страна</label>
          <select name="country_code" required>
            <option value="">Выбери страну</option>
            <% countries.forEach(country => { %>
              <option value="<%= country.code %>"><%= country.name_ru %></option>
            <% }) %>
          </select>
        </div>

        <div class="field">
          <label>Доп. название узла</label>
          <input name="label_suffix" placeholder="например: 1, 2, Frankfurt, Hetzner" />
          <small class="hint">Например: Германия + 1 = Германия-1. Флаг и страна остаются от выбранной страны в подписке.</small>
        </div>

        <div class="field">
          <label>Panel URL</label>
          <input name="panel_url" placeholder="https://panel.example.com:2053" required />
        </div>

        <div class="field">
          <label>Panel Path</label>
          <input name="panel_path" placeholder="/qwerty123" />
        </div>

        <div class="field half">
          <label>Логин панели</label>
          <input name="username" placeholder="admin" required />
        </div>

        <div class="field half">
          <label>Пароль панели</label>
          <input name="password" type="password" required />
        </div>

        <div class="field half">
          <label>Inbound ID</label>
          <input name="inbound_id" type="number" min="1" placeholder="1" required />
        </div>
      </div>

      <div class="actions node-actions">
        <button type="submit">Добавить узел</button>
      </div>
    </form>
  </section>

  <section class="card span-6">
    <h2>Подсказка</h2>
    <div class="kv-list">
      <div class="kv-item">
        <strong>Отключение узла</strong>
        <div class="muted">Если на узле техработы, нажми «Отключить». Узел останется в панели, но исчезнет из SUB/JSON подписок клиентов.</div>
      </div>
      <div class="kv-item">
        <strong>Доп. название</strong>
        <div class="muted">Используется в названии сервера внутри подписки: Германия-1, Германия-2, Финляндия Hetzner.</div>
      </div>
      <div class="kv-item">
        <strong>Panel URL</strong>
        <div class="muted">Адрес панели 3x-ui/API, включая порт. Это не публичный адрес подписки.</div>
      </div>
      <div class="kv-item">
        <strong>Inbound ID</strong>
        <div class="muted">Inbound, куда агрегатор будет добавлять клиентов на этом узле.</div>
      </div>
    </div>
  </section>

  <section class="card span-12">
    <h2>Список узлов</h2>

    <% if (!nodes.length) { %>
      <p class="muted">Пока нет добавленных узлов.</p>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ID</th>
              <th>Название</th>
              <th>Panel URL</th>
              <th>Path</th>
              <th>Inbound</th>
              <th>Активность</th>
              <th>Статус</th>
              <th>Ошибка</th>
              <th>Действия</th>
            </tr>
          </thead>
          <tbody>
            <% nodes.forEach(node => {
              const suffix = (node.label_suffix || '').trim();
              const baseName = node.country_name_ru || node.name;
              const displayName = suffix
                ? (/^\d+$/.test(suffix) ? `${baseName}-${suffix}` : `${baseName} ${suffix}`)
                : baseName;
              const isEnabled = Number(node.enabled) === 1;
            %>
              <tr class="<%= isEnabled ? '' : 'muted-row' %>">
                <td><%= node.id %></td>
                <td><%= displayName %></td>
                <td class="mono"><%= node.panel_url %></td>
                <td class="mono"><%= node.panel_path || '-' %></td>
                <td><%= node.inbound_id %></td>
                <td>
                  <% if (isEnabled) { %>
                    <span class="badge online">Включён</span>
                  <% } else { %>
                    <span class="badge offline">Отключён</span>
                  <% } %>
                </td>
                <td><span class="badge <%= node.last_status || 'unknown' %>"><%= node.last_status || 'unknown' %></span></td>
                <td style="max-width:280px; word-break:break-word;"><%= node.last_error || '-' %></td>
                <td>
                  <div class="actions node-actions node-actions-4">
                    <form method="post" action="/nodes/<%= node.id %>/check" class="inline-form">
                      <button type="submit" class="secondary">Проверить</button>
                    </form>
                    <form method="post" action="/nodes/<%= node.id %>/toggle" class="inline-form" onsubmit="return confirm('<%= isEnabled ? 'Отключить узел из подписок?' : 'Включить узел обратно в подписки?' %>')">
                      <% if (isEnabled) { %>
                        <button type="submit" class="danger">Отключить</button>
                      <% } else { %>
                        <button type="submit" class="secondary">Включить</button>
                      <% } %>
                    </form>
                    <a href="/nodes/<%= node.id %>/edit" class="link-btn secondary">Изменить</a>
                    <form method="post" action="/nodes/<%= node.id %>/delete" class="inline-form" onsubmit="return confirm('Удалить узел?')">
                      <button type="submit" class="danger">Удалить</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>      <div class="mobile-node-list">
        <% nodes.forEach(node => {
          const suffix = (node.label_suffix || '').trim();
          const baseName = node.country_name_ru || node.name;
          const displayName = suffix
            ? (/^\d+$/.test(suffix) ? `${baseName}-${suffix}` : `${baseName} ${suffix}`)
            : baseName;
          const isEnabled = Number(node.enabled) === 1;
        %>
          <div class="mobile-node-card <%= isEnabled ? '' : 'muted-row' %>">
            <div class="mobile-node-main">
              <span class="mobile-node-id">#<%= node.id %></span>
              <div>
                <strong><%= displayName %></strong>
                <small>Inbound <%= node.inbound_id %> · <%= isEnabled ? 'Включён' : 'Отключён' %></small>
              </div>
            </div>
            <button type="button" class="btn-secondary" onclick="openNodeDetails(<%= node.id %>)">Детали</button>
          </div>

          <div id="nodeDetails-<%= node.id %>" class="modal hidden" onclick="closeNodeDetails(event, <%= node.id %>)">
            <div class="modal-card editor-modal" onclick="event.stopPropagation()">
              <button type="button" class="modal-close" onclick="hideNodeDetails(<%= node.id %>)">×</button>
              <h2><%= displayName %></h2>
              <div class="mobile-detail-list">
                <div><span>ID</span><strong><%= node.id %></strong></div>
                <div><span>Panel URL</span><code><%= node.panel_url %></code></div>
                <div><span>Path</span><code><%= node.panel_path || '-' %></code></div>
                <div><span>Inbound</span><strong><%= node.inbound_id %></strong></div>
                <div><span>Статус</span><strong><%= node.last_status || 'unknown' %></strong></div>
                <% if (node.last_error) { %><div><span>Ошибка</span><code><%= node.last_error %></code></div><% } %>
              </div>
              <div class="mobile-node-actions">
                <form method="post" action="/nodes/<%= node.id %>/check"><button type="submit" class="secondary">Проверить</button></form>
                <form method="post" action="/nodes/<%= node.id %>/toggle" onsubmit="return confirm('<%= isEnabled ? 'Отключить узел из подписок?' : 'Включить узел обратно в подписки?' %>')">
                  <% if (isEnabled) { %><button type="submit" class="danger">Отключить</button><% } else { %><button type="submit" class="secondary">Включить</button><% } %>
                </form>
                <a href="/nodes/<%= node.id %>/edit" class="link-btn secondary">Изменить</a>
                <form method="post" action="/nodes/<%= node.id %>/delete" onsubmit="return confirm('Удалить узел?')"><button type="submit" class="danger">Удалить</button></form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
      <script>
        function openNodeDetails(id) { document.getElementById('nodeDetails-' + id).classList.remove('hidden'); }
        function hideNodeDetails(id) { document.getElementById('nodeDetails-' + id).classList.add('hidden'); }
        function closeNodeDetails(e, id) { if (e.target.id === 'nodeDetails-' + id) hideNodeDetails(id); }
      </script>

</div>

<%- include('partials_footer') %>
