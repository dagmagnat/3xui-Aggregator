<%- include('partials_header') %>

<h1>Узлы</h1>

<% if (message) { %>
  <div class="alert ok"><%= message %></div>
<% } %>

<% if (error) { %>
  <div class="alert err"><%= error %></div>
<% } %>

<div class="row">
  <div class="card">
    <h2>Добавить узел</h2>
    <form method="post" action="/nodes">
      <label>Страна</label>
      <select name="country_code" required>
        <option value="">Выбери страну</option>
        <% countries.forEach(country => { %>
          <option value="<%= country.code %>"><%= country.flag %> <%= country.name_ru %></option>
        <% }) %>
      </select>

      <label>Panel URL</label>
      <input name="panel_url" placeholder="https://panel.example.com:2053" required />

      <label>Panel Path</label>
      <input name="panel_path" placeholder="/qwerty123" />

      <label>Логин панели</label>
      <input name="username" placeholder="admin" required />

      <label>Пароль панели</label>
      <input name="password" type="password" required />

      <label>Inbound ID</label>
      <input name="inbound_id" type="number" min="1" placeholder="1" required />

      <button type="submit">Добавить узел</button>
    </form>
  </div>

  <div class="card">
    <h2>Подсказка</h2>
    <p>Panel URL — это адрес панели 3x-ui, включая порт, если он используется.</p>
    <p>Panel Path — секретный путь панели, если он включён. Если пути нет, оставь поле пустым.</p>
    <p>Inbound ID — это inbound, куда агрегатор будет добавлять клиентов на этом узле.</p>
  </div>
</div>

<div class="card">
  <h2>Список узлов</h2>

  <% if (!nodes.length) { %>
    <p>Пока нет добавленных узлов.</p>
  <% } else { %>
    <table>
      <tr>
        <th>ID</th>
        <th>Страна</th>
        <th>Panel URL</th>
        <th>Path</th>
        <th>Inbound</th>
        <th>Статус</th>
        <th>Ошибка</th>
        <th>Действия</th>
      </tr>

      <% nodes.forEach(node => { %>
        <tr>
          <td><%= node.id %></td>
          <td><%= node.country_flag || '' %> <%= node.country_name_ru || node.name %></td>
          <td><%= node.panel_url %></td>
          <td><%= node.panel_path || '-' %></td>
          <td><%= node.inbound_id %></td>
          <td>
            <% if (node.last_status === 'online') { %>
              <span style="color:#16a34a;">online</span>
            <% } else if (node.last_status === 'offline') { %>
              <span style="color:#dc2626;">offline</span>
            <% } else { %>
              <span>unknown</span>
            <% } %>
          </td>
          <td style="max-width:280px; word-break:break-word;">
            <%= node.last_error || '-' %>
          </td>
          <td>
            <div style="display:flex; gap:8px; flex-wrap:wrap;">
              <form method="post" action="/nodes/<%= node.id %>/check">
                <button type="submit" style="width:auto">Проверить</button>
              </form>

              <a href="/nodes/<%= node.id %>/edit" class="link-btn" style="display:inline-flex; align-items:center;">Изменить</a>

              <form method="post" action="/nodes/<%= node.id %>/delete" onsubmit="return confirm('Удалить узел?')">
                <button type="submit" class="danger" style="width:auto">Удалить</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </table>
  <% } %>
</div>

<%- include('partials_footer') %>
