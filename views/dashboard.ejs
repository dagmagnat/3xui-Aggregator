<%- include('partials_header', { pageTitle: 'Главная', pageSubtitle: 'Обзор узлов и общей подписки', activePage: 'dashboard' }) %>
<%
  function flagIcon(code) {
    const cc = String(code || '').toLowerCase();
    if (!cc) return '';
    return '<img class="flag-icon" src="https://flagcdn.com/w20/' + cc + '.png" alt="' + cc.toUpperCase() + '" loading="lazy">';
  }
%>


<div class="grid">
  <section class="stats-card span-3">
    <div class="stats-label">Узлов</div>
    <div class="stats-number"><%= stats.nodes %></div>
  </section>
  <section class="stats-card span-3">
    <div class="stats-label">Клиентов</div>
    <div class="stats-number"><%= stats.clients %></div>
  </section>
  <section class="stats-card span-3">
    <div class="stats-label">Онлайн</div>
    <div class="stats-number"><%= stats.online %></div>
  </section>
  <section class="stats-card span-3">
    <div class="stats-label">Оффлайн</div>
    <div class="stats-number"><%= stats.offline %></div>
  </section>

  <section class="card span-12">
    <h2>Как это работает</h2>
    <ol class="list-steps">
      <li>Добавляешь сюда свои 3x-ui узлы.</li>
      <li>Для каждого узла указываешь inbound ID, куда надо добавлять клиентов.</li>
      <li>Создаёшь клиента один раз — панель создаёт его на выбранных узлах.</li>
      <li>Общая подписка доступна по ссылке вида <span class="code-inline"><%= baseUrl %>/sub/SLUG</span>.</li>
    </ol>
  </section>

  <section class="card span-12">
    <h2>Последние узлы</h2>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Имя</th><th>Статус</th></tr></thead>
        <tbody>
          <% nodes.forEach(node => { %>
            <tr>
              <td><%- flagIcon(node.country_code) %> <%= node.country_name_ru || node.name %><%= node.label_suffix ? (/^\d+$/.test(node.label_suffix) ? '-' + node.label_suffix : ' ' + node.label_suffix) : '' %></td>
              <td><span class="badge <%= node.last_status || 'unknown' %>"><%= node.last_status || 'unknown' %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </section>
</div>

<%- include('partials_footer') %>
