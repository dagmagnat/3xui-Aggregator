<form method="POST" action="/nodes/<%= node ? node.id : '' %>">
  <div>
    <label>Название</label>
    <input name="name" value="<%= node?.name || '' %>" required />
  </div>

  <div>
    <label>Panel URL (3x-ui)</label>
    <input name="panel_url" value="<%= node?.panel_url || '' %>" required />
  </div>

  <div>
    <label>Panel Path</label>
    <input name="panel_path" value="<%= node?.panel_path || '' %>" />
  </div>

  <div>
    <label>SUB Base URL (ВАЖНО)</label>
    <input name="sub_base_url" placeholder="https://fin.amoredd.ru:5228"
           value="<%= node?.sub_base_url || '' %>" />
  </div>

  <button type="submit">Сохранить</button>
</form>
